#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$ROOT_DIR"

URL="http://localhost:5173"

read_required_node_major() {
  local default_major="${WEBTMUX_NODE_MAJOR:-20}"
  if [[ -f "${ROOT_DIR}/.nvmrc" ]]; then
    local raw
    raw="$(tr -d '[:space:]' < "${ROOT_DIR}/.nvmrc")"
    if [[ "${raw}" =~ ^([0-9]+) ]]; then
      echo "${BASH_REMATCH[1]}"
      return
    fi
  fi
  echo "${default_major}"
}

activate_nvm_if_needed() {
  local required_major="$1"
  local current_major=""
  if command -v node >/dev/null 2>&1; then
    current_major="$(node -p 'process.versions.node.split(".")[0]' 2>/dev/null || true)"
  fi

  if [[ -n "${current_major}" && "${current_major}" -ge "${required_major}" ]]; then
    return
  fi

  local nvm_sh="${NVM_DIR:-$HOME/.nvm}/nvm.sh"
  if [[ -s "${nvm_sh}" ]]; then
    # shellcheck source=/dev/null
    source "${nvm_sh}"
    if [[ -f "${ROOT_DIR}/.nvmrc" ]]; then
      nvm use --silent >/dev/null || true
    fi
  fi
}

ensure_node_and_npm() {
  local required_major="$1"
  activate_nvm_if_needed "${required_major}"

  if ! command -v node >/dev/null 2>&1; then
    echo "Error: node is not installed or not in PATH." >&2
    exit 1
  fi
  if ! command -v npm >/dev/null 2>&1; then
    echo "Error: npm is not installed or not in PATH." >&2
    exit 1
  fi

  local node_major
  node_major="$(node -p 'process.versions.node.split(".")[0]')"
  if [[ "${node_major}" -lt "${required_major}" ]]; then
    echo "Error: Node.js ${required_major}+ is required, current is $(node -v)." >&2
    echo "Hint: run 'source ~/.nvm/nvm.sh && nvm use' in this repo." >&2
    exit 1
  fi
}

REQUIRED_NODE_MAJOR="$(read_required_node_major)"
ensure_node_and_npm "${REQUIRED_NODE_MAJOR}"

npm run dev &
DEV_PID=$!

cleanup() {
  if kill -0 "$DEV_PID" >/dev/null 2>&1; then
    kill "$DEV_PID" >/dev/null 2>&1 || true
    wait "$DEV_PID" 2>/dev/null || true
  fi
}
trap cleanup EXIT INT TERM

echo "Waiting for dev server at $URL ..."
for _ in $(seq 1 120); do
  if curl -fsS "$URL" >/dev/null 2>&1; then
    break
  fi
  sleep 0.25
done

if command -v xdg-open >/dev/null 2>&1; then
  xdg-open "$URL" >/dev/null 2>&1 || true
else
  echo "xdg-open not found. Open this URL manually: $URL"
fi

wait "$DEV_PID"
