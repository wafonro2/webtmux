# Single-user password required to access the app
WEBTMUX_PASSWORD=change-this-password

# Optional
PORT=3001
# Set to 1 only when serving over HTTPS
WEBTMUX_COOKIE_SECURE=0

# Local faster-whisper speech-to-text (optional but recommended for voice mode)
WEBTMUX_PYTHON_BIN=python3
FASTER_WHISPER_MODEL=large-v3-turbo
FASTER_WHISPER_DEVICE=auto
FASTER_WHISPER_COMPUTE_TYPE=float16
FASTER_WHISPER_BEAM_SIZE=1
FASTER_WHISPER_VAD_FILTER=1
